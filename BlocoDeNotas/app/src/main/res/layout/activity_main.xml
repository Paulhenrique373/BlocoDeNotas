<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F4F5F7">

    <!-- 🔎 TOOLBAR -->
    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:title="Minhas Notas"
        android:titleTextColor="#202124"
        android:background="#FFFFFF"
        android:elevation="4dp" />

    <!-- 🔥 HEADER -->
    <LinearLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:layout_below="@id/toolbar">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/minhas_notas"
            android:textColor="#202124"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/subtitulo_notas"
            android:textColor="#777777"
            android:textSize="15sp" />

    </LinearLayout>

    <!-- 🔥 BOTÃO EXCLUIR (PROFISSIONAL) -->
    <Button
        android:id="@+id/btnDelete"
        android:layout_width="match_parent"
        android:layout_height="50dp"

        android:text="Excluir"
        android:textAllCaps="false"
        android:textColor="#FFFFFF"

        android:backgroundTint="#E53935"

        android:layout_below="@id/header"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginTop="8dp"

        android:visibility="gone" />

    <!-- 📋 LISTA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/btnDelete"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingBottom="120dp"
        android:clipToPadding="false" />

    <!-- ➕ BOTÃO ADD -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAdd"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"

        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"

        android:layout_marginEnd="20dp"
        android:layout_marginBottom="90dp"

        android:contentDescription="Adicionar nota"
        android:src="@drawable/outline_add_24"
        android:tint="#FFFFFF"

        app:backgroundTint="#4A90E2"
        app:elevation="12dp"
        app:fabSize="normal" />

</RelativeLayout>