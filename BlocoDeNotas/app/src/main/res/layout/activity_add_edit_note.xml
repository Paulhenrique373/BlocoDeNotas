<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 🔥 TÍTULO -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nova Anotação"
            android:textColor="#1F1F1F"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Escreva algo importante"
            android:textColor="#7A7A7A"
            android:textSize="14sp" />

        <!-- 🎨 CORES -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp">

            <View android:id="@+id/colorYellow" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp" android:background="#FFE7C2"/>
            <View android:id="@+id/colorBlue" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp" android:background="#D9F4FF"/>
            <View android:id="@+id/colorPurple" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp" android:background="#F6D8FF"/>
            <View android:id="@+id/colorGreen" android:layout_width="40dp" android:layout_height="40dp" android:layout_marginEnd="10dp" android:background="#DFFFD8"/>
            <View android:id="@+id/colorOrange" android:layout_width="40dp" android:layout_height="40dp" android:background="#FFF3C7"/>

        </LinearLayout>

        <!-- 🧠 CARD -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="20dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="#FFFFFF">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- TÍTULO -->
                <EditText
                    android:id="@+id/edtTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@android:color/transparent"
                    android:hint="Título"
                    android:textColor="#1F1F1F"
                    android:textColorHint="#999999"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:maxLines="1" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="12dp"
                    android:layout_marginBottom="12dp"
                    android:background="#EEEEEE" />

                <!-- 🔥 BARRA DE FORMATAÇÃO -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <Button
                        android:id="@+id/btnBold"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:text="B"
                        android:textStyle="bold"/>

                    <Button
                        android:id="@+id/btnItalic"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:text="I"/>

                    <Button
                        android:id="@+id/btnUnderline"
                        android:layout_width="48dp"
                        android:layout_height="40dp"
                        android:text="U"/>
                </LinearLayout>

                <!-- TEXTO -->
                <EditText
                    android:id="@+id/edtDescription"
                    android:layout_width="match_parent"
                    android:layout_height="220dp"
                    android:background="@android:color/transparent"
                    android:gravity="top"
                    android:hint="Digite sua anotação..."
                    android:inputType="textMultiLine"
                    android:textColor="#444444"
                    android:textColorHint="#AAAAAA"
                    android:textSize="16sp"
                    android:minLines="5" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- BOTÃO -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="28dp"
            android:backgroundTint="#4CAF50"
            android:text="Salvar anotação"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</ScrollView>